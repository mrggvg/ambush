meta {
  name: Create Proxy Credential
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/proxy/credentials
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "username": "scraper1",
    "password": "supersecret"
  }
}

vars:pre-request {
  baseUrl: 127.0.0.1:8081
}
